# ── Supabase (Project Settings → API) ──────────────────────────────
# Safe to expose in the browser — these are the public client keys.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: the Anthropic API key is NOT a frontend variable. It lives only
# as a Supabase Edge Function secret so it never ships to the browser:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
