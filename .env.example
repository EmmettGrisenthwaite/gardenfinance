# ── Supabase (Project Settings → API) ──────────────────────────────
# Safe to expose in the browser — these are the public client keys.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Internal rollback only. Omit for the illustrated Home experience; set to
# "3d" at build time to restore the previous full-screen garden after redeploy.
# VITE_GARDEN_EXPERIENCE=3d

# NOTE: the Anthropic API key is NOT a frontend variable. It lives only
# as a Supabase Edge Function secret so it never ships to the browser:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
